<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="index"
    class="tab-bar-item"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <!-- 图标占位 -->
    <view class="tab-icon" data-icon="{{item.icon}}"></view>
    <text class="tab-text" style="color: {{index === selected ? selectedColor : color}}">{{item.text}}</text>

    <!-- 购物车角标 -->
    <view wx:if="{{index === 2 && cartBadge > 0}}" class="tab-badge">{{cartBadge > 99 ? '99+' : cartBadge}}</view>
  </view>
</view>
